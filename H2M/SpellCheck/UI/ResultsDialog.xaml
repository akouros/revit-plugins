<Window x:Class="H2M.ResultsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spell Check Results"
        Height="600" Width="1060"
        MinHeight="400" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Light-red background for read-only / non-editable rows -->
        <Style x:Key="ReadOnlyRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditable}" Value="False">
                    <Setter Property="Background" Value="#FFEEEE"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Compact button style for action columns -->
        <Style x:Key="GridButton" TargetType="Button">
            <Setter Property="Padding"  Value="6,2"/>
            <Setter Property="Margin"   Value="2,1"/>
            <Setter Property="MinWidth" Value="46"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- toolbar -->
            <RowDefinition Height="*"/>       <!-- grid -->
            <RowDefinition Height="Auto"/>   <!-- status bar + Done button -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════ TOOLBAR ═══════════════════════════════ -->
        <ToolBar Grid.Row="0" Margin="4,4,4,0">
            <Button Content="Fix All"
                    ToolTip="Apply the top suggestion to every instance of the selected word"
                    Click="FixAll_Click"/>
            <Button Content="Skip All"
                    ToolTip="Remove every instance of the selected word from the results"
                    Click="SkipAll_Click"/>
            <Button Content="Add to Dictionary"
                    ToolTip="Add the selected word to the firm approved-abbreviations list"
                    Click="AddToDictionary_Click"/>
            <Separator/>
            <ToggleButton x:Name="GroupBySheetToggle"
                          Content="Group by Sheet"
                          ToolTip="Toggle grouping of results by sheet number"
                          Checked="GroupBySheet_Checked"
                          Unchecked="GroupBySheet_Unchecked"/>
        </ToolBar>

        <!-- ═══════════════════════ DATA GRID ═════════════════════════════ -->
        <DataGrid Grid.Row="1"
                  x:Name="ResultsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowStyle="{StaticResource ReadOnlyRowStyle}"
                  Margin="4,4,4,0"
                  VirtualizingPanel.IsVirtualizing="True">

            <!-- GroupStyle shown when "Group by Sheet" is active -->
            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock FontWeight="Bold" Margin="4,4,0,2"
                                       Text="{Binding Name, StringFormat='Sheet: {0}'}"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </DataGrid.GroupStyle>

            <DataGrid.Columns>

                <!-- Misspelled Word -->
                <DataGridTextColumn Header="Misspelled Word"
                                    Binding="{Binding MisspelledWord}"
                                    Width="130" IsReadOnly="True"/>

                <!-- Sheet # -->
                <DataGridTextColumn Header="Sheet #"
                                    Binding="{Binding SheetNumber}"
                                    Width="70" IsReadOnly="True"/>

                <!-- Sheet Name -->
                <DataGridTextColumn Header="Sheet Name"
                                    Binding="{Binding SheetName}"
                                    Width="190" IsReadOnly="True"/>

                <!-- Element Type -->
                <DataGridTextColumn Header="Element Type"
                                    Binding="{Binding ElementType}"
                                    Width="120" IsReadOnly="True"/>

                <!-- Suggestions ComboBox -->
                <DataGridTemplateColumn Header="Suggestions" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding Suggestions}"
                                      SelectedItem="{Binding SelectedSuggestion,
                                                    Mode=TwoWay,
                                                    UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding IsEditable}"
                                      Margin="2,1"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Fix button -->
                <DataGridTemplateColumn Header="Fix" Width="58">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Fix"
                                    Style="{StaticResource GridButton}"
                                    IsEnabled="{Binding IsEditable}"
                                    ToolTip="{Binding FixButtonTooltip}"
                                    Tag="{Binding}"
                                    Click="FixRow_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Skip button -->
                <DataGridTemplateColumn Header="Skip" Width="58">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Skip"
                                    Style="{StaticResource GridButton}"
                                    Tag="{Binding}"
                                    Click="SkipRow_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Navigate button -->
                <DataGridTemplateColumn Header="Navigate" Width="72">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Go To"
                                    Style="{StaticResource GridButton}"
                                    Tag="{Binding}"
                                    Click="Navigate_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══════════════════════ STATUS BAR ════════════════════════════ -->
        <Border Grid.Row="2"
                BorderBrush="#CCCCCC" BorderThickness="0,1,0,0"
                Padding="8,6">
            <Grid>
                <TextBlock x:Name="IssueCountText"
                           VerticalAlignment="Center"
                           Foreground="#444444"/>
                <Button Content="Done"
                        Width="80"
                        HorizontalAlignment="Right"
                        Click="Done_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
