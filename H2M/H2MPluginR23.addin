		<Name>Sheet Count Command</Name>
		<FullClassName>H2M.SheetCountCommand</FullClassName>
		<Text>Sheet Count</Text>
		<Description>Count and update sheets from Excel</Description>
		<Assembly>H2MPluginR23.dll</Assembly>
		<AddInId>
			ED051673-AC78-4F80-A354-D55157379910
		</AddInId>
		<VendorId>H2M</VendorId>
		<VendorDescription>H2M, www.h2m.com</VendorDescription>
