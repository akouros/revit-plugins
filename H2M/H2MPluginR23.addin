		<AddInId>
			80105A12-66D6-4D30-A8A2-27593A98E4BC
		</AddInId>
		<VendorId>H2M</VendorId>
		<VendorDescription>H2M, www.h2m.com</VendorDescription>
	</AddIn>

	<!-- Command Add-in for ViewNumberingCommand -->
	<AddIn Type="Command">
		<Name>View Numbering Command</Name>
		<FullClassName>H2M.ViewNumberingCommand</FullClassName>
		<Text>View Numbering</Text>
		<Description>Renumber views on sheets</Description>
		<Assembly>H2MPluginR23.dll</Assembly>
		<AddInId>
			3E214B35-0B98-4C41-9D28-8BC580D4D089
		</AddInId>
		<VendorId>H2M</VendorId>
		<VendorDescription>H2M, www.h2m.com</VendorDescription>
	</AddIn>

	<!-- Command Add-in for SheetCountCommand -->
