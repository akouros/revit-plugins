<?xml version="1.0" encoding="utf-8"?>
<RevitAddIns>
	<AddIn Type="Application">
		<Name>H2MPluginR2023</Name>
		<FullClassName>H2M.H2MPluginR23</FullClassName>
		<Text>H2M Plugins Revit 2023</Text>
		<Description>Tools including view numbering and sheet count automation</Description>
		<VisibilityMode>AlwaysVisible</VisibilityMode>
